# Database Configuration
# For AWS RDS PostgreSQL, use the following format:
# DATABASE_URL="postgresql://username:password@host:port/database?sslmode=require"
# Example: DATABASE_URL="postgresql://admin:password@mydb.cluster-xyz.us-east-1.rds.amazonaws.com:5432/emergency?sslmode=require"

DATABASE_URL="postgresql://username:password@localhost:5432/emergency_db?sslmode=require"

# Direct URL for connection pooling (optional, recommended for production)
# For AWS RDS with connection pooling (e.g., PgBouncer or Prisma Accelerate)
DIRECT_URL="postgresql://username:password@localhost:5432/emergency_db?sslmode=require&pgbouncer=true"

# App Configuration
APP_NAME="techhunter-backend"
NODE_ENV="development"

# Security (add these for production)
# JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
# ENCRYPTION_KEY="your-32-character-encryption-key"

# AWS Configuration (if using AWS services)
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# S3_BUCKET_NAME="emergency-images-bucket"

# Real-time (if using Pusher for real-time updates)
# PUSHER_APP_ID="your-pusher-app-id"
# PUSHER_KEY="your-pusher-key"
# PUSHER_SECRET="your-pusher-secret"
# PUSHER_CLUSTER="your-pusher-cluster"
